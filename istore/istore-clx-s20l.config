CONFIG_VERSION_REPO="https://raw.githubusercontent.com/etircopyh/openwrt-Flint2-custom-build/refs/heads/master"
CONFIG_VERSION_SUPPORT_URL=""
CONFIG_WARP_CHIPSET="mt7986"
CONFIG_WARP_NEW_FW=y
CONFIG_WARP_VERSION=2
# CONFIG_WOLFSSL_HAS_ECC25519 is not set
CONFIG_ZLIB_OPTIMIZE_SPEED=y
CONFIG_ZSTD_OPTIMIZE_O3=y
CONFIG_first_card_name="MT7986"
# CONFIG_MTK_BAND_STEERING is not set
# CONFIG_MTK_DEFAULT_5G_PROFILE is not set
# CONFIG_MTK_MAC_REPEATER_SUPPORT is not set
# CONFIG_MTK_MULTI_PROFILE_SUPPORT is not set
# CONFIG_MTK_PCIE_ASPM_DYM_CTRL_SUPPORT is not set
# CONFIG_MTK_PRE_CAL_TRX_SET1_SUPPORT is not set
# CONFIG_MTK_PRE_CAL_TRX_SET2_SUPPORT is not set
# CONFIG_MTK_RLM_CAL_CACHE_SUPPORT is not set
# CONFIG_MTK_SNIFFER_RADIOTAP_SUPPORT is not set
# CONFIG_PACKAGE_blkdiscard is not set
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_kmod-crypto-ccm=y
CONFIG_PACKAGE_kmod-crypto-cmac=y
CONFIG_PACKAGE_kmod-crypto-ctr=y
CONFIG_PACKAGE_kmod-crypto-gcm=y
CONFIG_PACKAGE_kmod-crypto-geniv=y
CONFIG_PACKAGE_kmod-crypto-gf128=y
CONFIG_PACKAGE_kmod-crypto-ghash=y
CONFIG_PACKAGE_kmod-crypto-seqiv=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_libblkid=y
CONFIG_PACKAGE_libkmod=m
CONFIG_PACKAGE_libpci=m
CONFIG_PACKAGE_libuuid=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_pciids=m
CONFIG_PACKAGE_pciutils=m
# ====================== 你指定要加的插件 ======================

# WireGuard
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y

# OpenVPN Server
CONFIG_PACKAGE_openvpn-mbedtls=y
CONFIG_PACKAGE_luci-app-openvpn-server=y

# iStore 应用商店
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y

# AppFilter 应用过滤
CONFIG_PACKAGE_luci-app-appfilter=y

# ARP绑定 IP/MAC绑定
CONFIG_PACKAGE_luci-app-arpbind=y

# 定时重启
CONFIG_PACKAGE_luci-app-autoreboot=y

# DDNS 动态域名
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_curl=y

# Tailscale
CONFIG_PACKAGE_tailscale-community=y
CONFIG_PACKAGE_luci-app-tailscale=y

# 计划任务 Taskplan
CONFIG_PACKAGE_luci-app-taskplan=y

# 上网时间控制 Timecontrol
CONFIG_PACKAGE_luci-app-timecontrol=y

# 网络唤醒 WOL
CONFIG_PACKAGE_luci-app-wol=y

# 流量监控 wrtbwmon
CONFIG_PACKAGE_luci-app-wrtbwmon=y
CONFIG_PACKAGE_wrtbwmon=y

# 认证防护 AuthShield
CONFIG_PACKAGE_luci-app-authshield=y

# ====================== 必要依赖（保证能编译） ======================
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-udptunnel4=y
CONFIG_PACKAGE_kmod-udptunnel6=y
CONFIG_PACKAGE_libcares=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libnetconf2=y
CONFIG_PACKAGE_libssh=y
CONFIG_PACKAGE_libwrap=y
CONFIG_PACKAGE_zlib=y

# ====================== 新增：存储/磁盘管理 ======================
# Samba 网络共享 (完整版)
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_samba4-common=y

# DiskMan 磁盘管理 (含格式化硬盘功能)
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_mkf2fs=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_gdisk=y

# ====================== 新增：下载工具 ======================
# Aria2 下载 (带 WebUI)
CONFIG_PACKAGE_luci-app-aria2=y
CONFIG_PACKAGE_luci-i18n-aria2-zh-cn=y
CONFIG_PACKAGE_aria2=y
CONFIG_PACKAGE_aria2-cli=y
CONFIG_PACKAGE_aria2-conf=y

# qBittorrent 下载 (完整版)
CONFIG_PACKAGE_luci-app-qbittorrent=y
CONFIG_PACKAGE_luci-i18n-qbittorrent-zh-cn=y
CONFIG_PACKAGE_qbittorrent-nox=y
CONFIG_PACKAGE_libtorrent-rasterbar=y

# Transmission 下载
CONFIG_PACKAGE_luci-app-transmission=y
CONFIG_PACKAGE_luci-i18n-transmission-zh-cn=y
CONFIG_PACKAGE_transmission-daemon=y
CONFIG_PACKAGE_transmission-web=y

# ====================== 新增：Docker (容器管理) ======================
# Docker 核心
CONFIG_PACKAGE_docker-ce=y
CONFIG_PACKAGE_docker-ce-cli=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_containserd=y
CONFIG_PACKAGE_runc=y

# Docker LuCI 管理界面
CONFIG_PACKAGE_luci-app-docker=y
CONFIG_PACKAGE_luci-i18n-docker-zh-cn=y
CONFIG_PACKAGE_luci-lib-docker=y

# Docker 依赖
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nf-ipvs=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_cgroupfs-mount=y
CONFIG_PACKAGE_libnetwork=y

# ====================== 补充：存储依赖 ======================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y

# --- EMMC 工具 ---
CONFIG_PACKAGE_mmc-utils=y

# ---  M.2 接口支持 ---
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_kmod-nvme=y
